```gitignore
# =========================
# OS
# =========================
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# =========================
# ENV / SECRETS
# =========================
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.keystore
keystore.jks
google-services.json
GoogleService-Info.plist

# =========================
# LOGS
# =========================
logs/
*.log

# =========================
# JAVA / SPRING BOOT
# =========================
target/
build/
out/
bin/
*.class
*.jar
*.war
*.ear

# IntelliJ
.idea/
*.iml

# Eclipse / STS
.project
.classpath
.settings/
.springBeans
.sts4-cache

# NetBeans
nbproject/private/
nbbuild/
dist/
nbdist/
.nb-gradle/

# VSCode
.vscode/

# =========================
# NODE / REACT NATIVE
# =========================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Expo / Metro
.expo/
.expo-shared/
.metro-health-check*

# Android
android/.gradle/
android/build/
android/app/build/

# iOS
ios/build/
ios/Pods/

# Bundle outputs
*.bundle

# =========================
# CACHE / TEMP
# =========================
.cache/
.parcel-cache/
coverage/
.nyc_output/
tmp/
temp/

# =========================
# DATABASE LOCAL FILES
# =========================
*.sqlite
*.db
```
